{
  "name": "kura-ui",
  "version": "0.0.1",
  "description": "Kura UI interface layer for Project Kura",
  "author": "Walteria.net",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun run build:manifest && bun run build:web",
    "build:manifest": "bun build.js",
    "build:web": "bun x vite build --config web/vite.config.ts",
    "dev:web": "bun x vite --config web/vite.config.ts",
    "dev:game": "bun x vite build --watch --config web/vite.config.ts",
    "check": "bun x tsc --noEmit",
    "lint": "bun x biome check build.js package.json tsconfig.json biome.json web/index.html web/vite.config.ts web/src",
    "format": "bun x biome format --write build.js package.json tsconfig.json biome.json web/index.html web/vite.config.ts web/src"
  },
  "dependencies": {
    "@fontsource-variable/instrument-sans": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tailwindcss/vite": "^4.1.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "typescript": "^5.8.3",
    "vite": "^7.0.6"
  }
}
